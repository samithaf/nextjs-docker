name: Deployment

on:
  workflow_dispatch:
    inputs:
      environment:
        description: 'Target environment'
        required: true
        type: choice
        options:
        - dev
        - sit
        - svp
        - prod
      version:
        description: 'Version number (e.g. 1.2.3)'
        required: true
        type: string
      deployment_name:
        description: 'Deployment name (e.g. ui-andromeda-secure-investments)'
        required: true
        type: string
        default: 'ui-andromeda-secure-investments'

jobs:
  validate:
    runs-on: arc-runner-set
    outputs:
      image_tag: ${{ steps.set-vars.outputs.image_tag }}
    steps:
    - name: Validate inputs
      run: |
        if [[ ! "${{ inputs.version }}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
          echo "::error::Version must be in semver format (e.g. 1.2.3)"
          exit 1
        fi
        echo "Deploying ${{ inputs.deployment_name }} version ${{ inputs.version }}"

    - name: Set variables
      id: set-vars
      run: |
        echo "image_tag=${{ inputs.deployment_name }}:${{ inputs.version }}" >> "$GITHUB_OUTPUT"

  deploy:
    needs: validate
    runs-on: arc-runner-set
    environment: ${{ inputs.environment }}
    steps:
    - uses: actions/checkout@v4
      with:
        ref: v${{ inputs.version }}

    - name: Deploy to ${{ inputs.environment }}
      run: |
        echo "=== Deployment ==="
        echo "Environment: ${{ inputs.environment }}"
        echo "Deployment:  ${{ inputs.deployment_name }}"
        echo "Version:     ${{ inputs.version }}"
        echo "Image:       ${{ needs.validate.outputs.image_tag }}"
        echo "Triggered by: ${{ github.actor }}"
        echo "=================="
        # Add your deployment commands here
